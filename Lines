import sys
if len(sys.argv) != 2:
    sys.exit("Too few or too many arguments")
if not sys.argv[1].endswith(".py"):
    sys.exit("Not a Python file")
try:
    with open(sys.argv[1]) as file:
        count = 0
        for line in file:
            if line.strip() == "" :
                continue
            line = line.lstrip()
            if line.startswith("#") :
                continue
            else :
                count += 1
except FileNotFoundError:
    sys.exit("File does not exist")
print(count)
