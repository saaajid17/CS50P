while True :
    try:
        text = (input("Fraction: "))
        x,y = text.split("/")
        x = int(x)
        y  = int(y)
        z= float(x/y) 
        if z==0 :
            print("E")
        elif z==1 :
            print("F")
        else :
            print(f"{int(z*100)}%")    
        break
    except ValueError :
        pass
    except ZeroDivisionError :
        pass
 

