def main():
    text = input("What time is it? ")
    print(convert(text))

def convert(time):
    first = float(time.split(":")[0])
    last = float(time.split(":")[1])
    z = last/60 
    total = first + z
    if 7.0 <= total <=8.0 :
        return "breakfast time"
    elif 12.0 <= total <=13.0 :
        return "lunch time"
    elif 18.0 <= total <=19.0 :
        return "dinner time"
    else :
        return ""
main()

