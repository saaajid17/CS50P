price = int(50) 
print("Anount due: ",price)
while price >0 :
    given = int(input("Insert coin: "))
    if given == 5 or given == 10 or given == 25 :
        price = price - given
        if price<0 :
            print("Change Owed: ",price*-1)
        elif price==0 :
            print("Change Owed: ",0)
        else :
            print("Amount Due: ",price)
    else :
        print("Amount Due: ",price)
